e:T61c,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How do I book a vehicle?","acceptedAnswer":{"@type":"Answer","text":"You can book online through our booking system, submit an enquiry through our contact form, or call us directly on (02) 4390 5043."}},{"@type":"Question","name":"What areas do you service?","acceptedAnswer":{"@type":"Answer","text":"We service the entire Central Coast region of New South Wales, including Gosford, Wyong, Terrigal, Erina, Woy Woy, and The Entrance. We also cover Sydney, Newcastle, the Hunter Valley, and surrounding areas."}},{"@type":"Question","name":"How far in advance should I book?","acceptedAnswer":{"@type":"Answer","text":"We recommend booking as early as possible, particularly for weddings and major events. However, we can often accommodate last-minute requests subject to availability."}},{"@type":"Question","name":"What is your cancellation policy?","acceptedAnswer":{"@type":"Answer","text":"Cancellations made more than 48 hours in advance receive a full refund. Please contact us for specific details regarding your booking."}},{"@type":"Question","name":"Do you provide child seats?","acceptedAnswer":{"@type":"Answer","text":"Yes, child seats and booster seats are available upon request at no additional charge."}},{"@type":"Question","name":"Is there a minimum hire time?","acceptedAnswer":{"@type":"Answer","text":"Minimum hire times vary by service. Airport transfers have no minimum, while party and event bookings typically require a minimum of 3 hours."}}]}b:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$e"}}],["$","section",null,{"className":"relative min-h-screen flex items-center overflow-hidden","data-testid":"section-hero","children":[["$","$Lf",null,{"src":"/images/hero-bg.png","alt":"Luxury Mercedes Sprinter at hotel entrance","fill":true,"sizes":"100vw","className":"object-cover","priority":true,"qualit